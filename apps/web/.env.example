# --- アプリ固有変数（apps/web 専用）---
# cp apps/web/.env.example apps/web/.env
# 通常は変更不要（API_PORT=3000 / WEB_PORT=5173 のまま）

# API proxy target のポート（Vite が転送先 API サーバーに接続するポート）
# split モード（別コンテナ）ではコンテナ内部ポートが常に 3000 のため変更不要。
# nested モードで並行 dev する場合のみ、apps/api/.env の PORT に合わせて変更する。
API_PORT=3000

# Vite dev server のリッスンポート（nested 並行実行時のみ変更）
WEB_PORT=5173

# --- Error tracking（Sentry / 任意・ADR-0035） ---
# 未設定なら error tracking は無効。VITE_ 接頭辞のため Vite が build-time で
# バンドルへ埋め込み、ブラウザに公開される（web の DSN は公開前提・ADR-0035）。
# api 用の SENTRY_DSN とは別プロジェクト/別 DSN にするのが望ましい。
# VITE_SENTRY_DSN=https://<publicKey>@<org>.ingest.sentry.io/<projectId>
