# --- アプリ固有変数（apps/api 専用）---
# このファイルをコピーして LLM_API_KEY を設定しないと bun run dev が起動しない
# cp apps/api/.env.example apps/api/.env

# LLM 設定: Anthropic 互換 API の接続情報
# SSoT: docs/guides/free-llm-setup.md

# --- Option A: OpenRouter（推奨・無料） ---
# https://openrouter.ai に登録して API キーを取得
LLM_API_KEY=sk-or-YOUR_OPENROUTER_KEY_HERE
LLM_BASE_URL=https://openrouter.ai/api
# 無料モデルの場合は以下をいずれかに変更（コメント解除）
# LLM_MODEL=llama-3.3-70b-specdec
# LLM_MODEL=deepseek-r1
# LLM_MODEL=qwen/qwen-coder-480b

# --- Option B: Ollama（代替・ローカル無料） ---
# Ollama をローカルで起動している場合に切り替え
# ollama serve を実行してから以下を有効化
# ANTHROPIC_BASE_URL=http://localhost:11434
# LLM_MODEL=llama2:70b

# --- Option C: Anthropic 本家（有料） ---
# デフォルト（コメント時）は api.anthropic.com を使用
# LLM_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE
# LLM_BASE_URL=https://api.anthropic.com

# API サーバーのリッスンポート（nested 並行実行時のみ変更。通常は 3000）
# 変更する場合は apps/web/.env の API_PORT も同じ値に設定する
# PORT=3000
