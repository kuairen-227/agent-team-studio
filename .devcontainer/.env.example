# ===========================================
# DevContainer compose 用の環境変数テンプレート
# このファイルを .devcontainer/.env にコピーして
# 各 worktree ごとに値を上書きする
# ===========================================

# worktree 識別子（メインツリーは main、worktree 内では任意の名前に）
WORKTREE_ID=main

# ポート割当（worktree ごとに +10 オフセットで衝突を回避）
APP_PORT=3000
DB_PORT=5432

# DB 隔離モードを使う場合は worktree 単位の volume 名に変更
# 例: agent-team-studio-pgdata-feat-auth
DB_VOLUME=agent-team-studio-pgdata-main

# DB 名（worktree ごとに分けたい場合に変更）
POSTGRES_DB=agent_team_studio

# PostgreSQL の認証情報（ローカル開発専用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
