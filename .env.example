# ===========================================
# 環境変数テンプレート
# このファイルを .env にコピーして値を設定する
# cp .env.example .env
# ===========================================

# --- AI ---
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- Database ---
# DevContainer 内では compose の db サービスへ接続する
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# ホストから接続する場合は db を localhost、5432 を ${DB_PORT} に置き換える
