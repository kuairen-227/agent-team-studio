# ===========================================
# 環境変数テンプレート
# このファイルを .env にコピーして値を設定する
# cp .env.example .env
# ===========================================

# --- LLM ---
# `@anthropic-ai/sdk` が接続するエンドポイントを LLM_API_KEY / LLM_BASE_URL で設定する
# LLM_BASE_URL を省略すると Anthropic 本家 (api.anthropic.com) を使用する
LLM_API_KEY=YOUR_KEY_HERE
# LLM_BASE_URL=https://api.z.ai/v1  # z.ai (GLM) を使う場合のみ設定

# --- Database (compose が app / db 両コンテナに展開) ---
# DATABASE_URL は compose 内で組み立てて app コンテナに注入するため、
# .env では部品のみを管理する。
# 以下の既定値は **ローカル開発専用**。本番では別途シークレット管理で上書きすること（ADR-0018）。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_team_studio

# --- DevContainer / Worktree ---
# worktree 識別子（メインツリーは main、worktree 内では任意の名前に）
WORKTREE_ID=main

# ホスト側公開ポート（worktree ごとに +10 オフセットで衝突回避。命名規約は docs/guides/devcontainer.md）
APP_PORT=3000
DB_PORT=5432

# DB 隔離モードを使う場合は worktree 単位の volume 名に変更
# 例: agent-team-studio-pgdata-feat-auth
DB_VOLUME=agent-team-studio-pgdata-main
