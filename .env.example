# ===========================================
# 環境変数テンプレート
# このファイルを .env にコピーして値を設定する
# cp .env.example .env
# ===========================================

# --- AI ---
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- Database ---
# DevContainer 内（既定）: compose の db サービスに接続する
# .devcontainer/.env の POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB を変更した場合は本値も合わせて更新する
DATABASE_URL=postgresql://postgres:postgres@db:5432/agent_team_studio
# ホストから接続する場合（DevContainer を使わずに psql 等で繋ぐとき）は以下に置き換える
# 5432 部分は .devcontainer/.env の DB_PORT に合わせる
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_team_studio
