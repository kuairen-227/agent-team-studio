{
  "name": "agent-team-studio",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:md": "markdownlint-cli2",
    "lint:md-links": "git ls-files -z '*.md' ':(exclude)*template.md' | xargs -0 markdown-link-check --config .markdown-link-check.json --quiet",
    "lint:secret": "secretlint '**/*'",
    "lint:spell": "cspell --no-progress --no-must-find-files '**'",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/bun": "^1.3.14",
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.22.1",
    "secretlint": "^13.0.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
