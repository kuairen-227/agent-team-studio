{
  "name": "agent-team-studio",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:md": "markdownlint-cli2",
    "lint:links": "find . \\( -path '*/node_modules' -o -path './_dev' -o -path './.playwright-mcp' -o -path './.claude/worktrees' -o -name 'template.md' \\) -prune -o -name '*.md' -print | xargs markdown-link-check --config .markdown-link-check.json --quiet",
    "lint:secret": "secretlint '**/*'",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.22.1",
    "secretlint": "^13.0.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
