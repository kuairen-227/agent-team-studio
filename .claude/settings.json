{
  "enabledMcpjsonServers": ["context7", "playwright"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/status-line-command.sh"
  },
  "permissions": {
    "allow": [
      "Skill(cleanup-merged-branch)",
      "Skill(create-adr)",
      "Skill(create-issue)",
      "Skill(create-pr)",
      "Skill(implement-feature)",
      "Skill(manage-issue)",
      "Skill(process-issue)",
      "Skill(resolve-review)",
      "Skill(review)",
      "mcp__context7",
      "mcp__playwright",
      "Bash(bun install:*)",
      "Bash(bun ls:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun -v)",
      "Bash(bun --version)",
      "Bash(bunx shadcn:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git check-ignore:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree list:*)",
      "Bash(git worktree remove:*)",
      "Bash(grep:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh api repos/:owner/:repo/issues:*)",
      "Bash(gh api repos/:owner/:repo/issues/*/sub_issues:*)",
      "Bash(gh api -X POST repos/:owner/:repo/issues:*)",
      "Bash(gh api repos/:owner/:repo/pulls:*)",
      "Bash(gh api repos/:owner/:repo/milestones:*)",
      "Bash(gh api -X PATCH repos/:owner/:repo/milestones:*)",
      "Bash(gh label list:*)",
      "Bash(gh milestone list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh run view:*)",
      "Bash(npm info:*)",
      "Bash(npm view:*)",
      "Bash(wait:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Bash(gh run rerun --debug:*)",
      "Bash(rm -rf *)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "mcp__playwright__browser_run_code_unsafe",
      "mcp__playwright__browser_evaluate"
    ]
  }
}
