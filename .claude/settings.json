{
  "statusLine": {
    "type": "command",
    "command": "bash /workspaces/agent-team-studio/.claude/status-line-command.sh"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(gh pr create:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
